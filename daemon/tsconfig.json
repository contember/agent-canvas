{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["@types/bun"],
    "paths": {
      "#canvas/runtime": ["./client/runtime.ts"],
      "#canvas/components": ["./client/components/index.ts"]
    }
  },
  "include": ["src/**/*", "client/**/*"],
  "exclude": ["client/compat/**/*"]
}
